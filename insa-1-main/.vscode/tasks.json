{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 개발 서버 시작 (포트 8080)",
      "type": "shell",
      "command": "npm run dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "line": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting server process",
          "endsPattern": "Server running on port"
        }
      }
    },
    {
      "label": "🛑 개발 서버 종료",
      "type": "shell",
      "command": "taskkill /F /IM node.exe 2>nul || echo '실행 중인 서버 없음'",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "📦 의존성 설치",
      "type": "shell",
      "command": "npm install",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 타입 검사",
      "type": "shell",
      "command": "npm run lint",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    }
  ]
}
