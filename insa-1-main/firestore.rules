rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function getUser(email) {
      return get(/databases/$(database)/documents/users/$(email)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && getUser(request.auth.token.email).role == 'admin';
    }

    function isHr() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && (getUser(request.auth.token.email).role == 'admin' || getUser(request.auth.token.email).role == 'hr');
    }

    // 민감 권한(menuPermissions·confirmDepartments)은 users 문서가 아닌 userAccess/{email} 문서에 보관
    // (users get 은 전체 허용이므로 권한 구조 노출을 막기 위해 분리)
    function accessExists() { return exists(/databases/$(database)/documents/userAccess/$(request.auth.token.email)); }
    function accessDoc() { return get(/databases/$(database)/documents/userAccess/$(request.auth.token.email)).data; }

    // 최종점수 확정 권한: 대상자(evaluatee)의 소속부서가 호출자의 confirmDepartments 목록에 포함될 때만 허용
    function canConfirmDeptOf(evaluateeId) {
      return isSignedIn()
        && evaluateeId is string
        && accessExists()
        && 'confirmDepartments' in accessDoc()
        && exists(/databases/$(database)/documents/users/$(evaluateeId))
        && getUser(evaluateeId).department in accessDoc().confirmDepartments;
    }

    // 사용자별 개별 메뉴 권한 체크 (userAccess 문서 기반)
    function hasMenuAccess(menuPath) {
      return isSignedIn()
        && accessExists()
        && 'menuPermissions' in accessDoc()
        && menuPath in accessDoc().menuPermissions
        && accessDoc().menuPermissions[menuPath] == true;
    }

    // 역할별 메뉴 권한 체크 (settings/menuPermissions 기반)
    function hasRoleMenuAccess(menuPath) {
      let u = getUser(request.auth.token.email);
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && exists(/databases/$(database)/documents/settings/menuPermissions)
        && menuPath in get(/databases/$(database)/documents/settings/menuPermissions).data
        && u.role in get(/databases/$(database)/documents/settings/menuPermissions).data[menuPath]
        && get(/databases/$(database)/documents/settings/menuPermissions).data[menuPath][u.role] == true;
    }

    // 개별 또는 역할별 메뉴 권한 중 하나라도 허용
    function canAccessMenu(menuPath) {
      return hasMenuAccess(menuPath) || hasRoleMenuAccess(menuPath);
    }

    match /users/{userId} {
      // 로그인한 사용자는 누구든 개별 사용자 문서 조회 가능 (평가자가 피평가자 이름/직급 표시 목적)
      // list(전체 목록 조회)는 별도로 HR/admin으로 제한
      allow get: if isSignedIn();

      allow update: if (
        isSignedIn() && (
          isAdmin() ||
          // 본인은 name, department, updatedAt, uid 만 수정 가능
          // (role, position, menuPermissions, mustChangePassword 자가수정 불가 —
          //  강제 비밀번호 변경 플래그 해제는 서버(Admin SDK)에서만 처리)
          (request.auth.token.email == userId
            && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department', 'updatedAt', 'uid']))
        )
      );

      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow list: if isHr() || isAdmin() || canAccessMenu('/admin/users') || canAccessMenu('/admin/scores');
    }

    // 민감 권한 문서: 본인 또는 관리자만 읽기, 쓰기는 관리자만
    match /userAccess/{email} {
      allow read: if isAdmin() || (isSignedIn() && email == request.auth.token.email);
      allow write: if isAdmin();
    }

    // 근태·업무일지 점수 (문서ID: {year}_{userId}, 문서 내 userId 필드 보유)
    // 읽기: 본인 점수 또는 HR·관리자·점수/결과 열람 권한자만 (타인 근태점수 무단열람 차단)
    match /periodicScores/{scoreId} {
      allow read: if isHr()
        || canAccessMenu('/admin/scores')
        || canAccessMenu('/admin/results')
        || canAccessMenu('/admin/results-executive')
        || (isSignedIn() && resource.data.userId == request.auth.token.email);
      allow write: if isAdmin() || canAccessMenu('/admin/scores');
    }

    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/menuPermissions {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /years/{yearId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isHr() || canAccessMenu('/admin/items');
    }

    match /assignments/{assignmentId} {
      // get: 개별 문서 조회 (평가자/피평가자 본인 또는 관리자)
      allow get: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/assignments') ||
        existing().evaluatorId == request.auth.token.email ||
        existing().evaluateeId == request.auth.token.email
      );
      // 관리자급은 전체 목록 허용. 일반 사용자는 자신이 평가자/피평가자인 문서만 허용.
      allow list: if isHr() || canAccessMenu('/admin/assignments') || canAccessMenu('/admin/results') ||
        (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         (resource.data.evaluatorId == request.auth.token.email || resource.data.evaluateeId == request.auth.token.email));

      allow create, delete: if (isHr() || canAccessMenu('/admin/assignments')) && isValidId(assignmentId);

      allow update: if isHr() || canAccessMenu('/admin/assignments') || (
        isSignedIn() && existing().evaluatorId == request.auth.token.email
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore'])
        // 평가자는 status를 pending 또는 completed 값으로만 변경 가능 (임의 문자열 방지)
        && incoming().status in ['pending', 'completed']
        && incoming().totalScore is number && incoming().totalScore >= 0 && incoming().totalScore <= 1000
      );
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/results') ||
        get(/databases/$(database)/documents/assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/results') ||
        get(/databases/$(database)/documents/assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /finalScores/{finalScoreId} {
      allow get: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/results') ||
        existing().evaluateeId == request.auth.token.email
      );
      // 관리자급은 전체 목록. 일반 직원은 자신이 피평가자인 점수만 조회 가능 (내 평가 이력).
      allow list: if isHr() || canAccessMenu('/admin/results') ||
        (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         resource.data.evaluateeId == request.auth.token.email);
      // 최종점수 확정/수정: HR·admin, /admin/results 권한자, 또는 대상자 소속부서 확정권한자(confirmDepartments)
      allow create, update: if isHr() || canAccessMenu('/admin/results') || canConfirmDeptOf(incoming().evaluateeId);
      allow delete: if isHr() || canAccessMenu('/admin/results') || canConfirmDeptOf(existing().evaluateeId);
    }

    match /exec_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isHr() || canAccessMenu('/admin/items-executive');
    }

    match /exec_assignments/{assignmentId} {
      allow get: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/assignments-executive') ||
        existing().evaluatorId == request.auth.token.email ||
        existing().evaluateeId == request.auth.token.email
      );
      allow list: if isHr() || canAccessMenu('/admin/assignments-executive') || canAccessMenu('/admin/results-executive') ||
        (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         (resource.data.evaluatorId == request.auth.token.email || resource.data.evaluateeId == request.auth.token.email));

      allow create, delete: if (isHr() || canAccessMenu('/admin/assignments-executive')) && isValidId(assignmentId);

      allow update: if isHr() || canAccessMenu('/admin/assignments-executive') || (
        isSignedIn() && existing().evaluatorId == request.auth.token.email
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore'])
        // 임의 status 문자열 방지
        && incoming().status in ['pending', 'completed']
        && incoming().totalScore is number && incoming().totalScore >= 0 && incoming().totalScore <= 1000
      );
    }

    match /exec_results/{resultId} {
      allow read: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/results-executive') ||
        get(/databases/$(database)/documents/exec_assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isHr() || canAccessMenu('/admin/results-executive') ||
        get(/databases/$(database)/documents/exec_assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /exec_finalScores/{finalScoreId} {
      allow get: if isSignedIn() && (
        isAdmin() || canAccessMenu('/admin/results-executive') ||
        existing().evaluateeId == request.auth.token.email
      );
      allow list: if isAdmin() || canAccessMenu('/admin/results-executive') ||
        (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
         resource.data.evaluateeId == request.auth.token.email);
      allow write: if isAdmin() || canAccessMenu('/admin/results-executive');
    }
  }
}
