rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function getUser(email) {
      return get(/databases/$(database)/documents/users/$(email)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && getUser(request.auth.token.email).role == 'admin';
    }

    function isHr() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && (getUser(request.auth.token.email).role == 'admin' || getUser(request.auth.token.email).role == 'hr');
    }

    function isGroupLeader() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && ('position' in getUser(request.auth.token.email)) && getUser(request.auth.token.email).position.matches('.*그룹장.*');
    }

    function isBoss() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && ('position' in getUser(request.auth.token.email)) && getUser(request.auth.token.email).position == '사장';
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow update: if (
        isSignedIn() && (
          isAdmin() ||
          (request.auth.token.email == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department', 'updatedAt', 'uid']))
        )
      );

      allow create: if isAdmin();

      allow delete: if isAdmin();

      allow list: if isHr() || isAdmin();
    }

    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /years/{yearId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /assignments/{assignmentId} {
      allow read: if isSignedIn() && (isHr() || isGroupLeader() || isBoss() || existing().evaluatorId == request.auth.token.email || existing().evaluateeId == request.auth.token.email);
      allow create, delete: if isHr() && isValidId(assignmentId);
      allow update: if isHr() || isGroupLeader() || (
        isSignedIn() && existing().evaluatorId == request.auth.token.email
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore'])
        && incoming().totalScore is number && incoming().totalScore >= 0
      );
      allow list: if isHr() || isGroupLeader() || isBoss() || (isSignedIn() && (resource.data.evaluatorId == request.auth.token.email || resource.data.evaluateeId == request.auth.token.email));
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && (
        isHr() || isGroupLeader() || isBoss() ||
        get(/databases/$(database)/documents/assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isHr() || isGroupLeader() ||
        get(/databases/$(database)/documents/assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /finalScores/{finalScoreId} {
      allow read: if isSignedIn() && (isHr() || isGroupLeader() || isBoss() || existing().evaluateeId == request.auth.token.email);
      allow create, update: if isHr() || isGroupLeader();
      allow delete: if isHr() || isGroupLeader();
      allow list: if isHr() || isGroupLeader() || isBoss() || (isSignedIn() && resource.data.evaluateeId == request.auth.token.email);
    }

    match /exec_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isHr() || isBoss();
    }

    match /exec_assignments/{assignmentId} {
      allow read: if isSignedIn() && (isHr() || isBoss() || existing().evaluatorId == request.auth.token.email || existing().evaluateeId == request.auth.token.email);
      allow create, delete: if (isHr() || isBoss()) && isValidId(assignmentId);
      allow update: if isHr() || isBoss() || (
        isSignedIn() && existing().evaluatorId == request.auth.token.email
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore'])
        && incoming().totalScore is number && incoming().totalScore >= 0
      );
      allow list: if isHr() || isBoss() || (isSignedIn() && (resource.data.evaluatorId == request.auth.token.email || resource.data.evaluateeId == request.auth.token.email));
    }

    match /exec_results/{resultId} {
      allow read: if isSignedIn() && (
        isHr() || isBoss() ||
        get(/databases/$(database)/documents/exec_assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isHr() || isBoss() ||
        get(/databases/$(database)/documents/exec_assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /exec_finalScores/{finalScoreId} {
      allow read: if isBoss() || isAdmin() || (isSignedIn() && existing().evaluateeId == request.auth.token.email);
      allow write: if isBoss() || isAdmin();
      allow list: if isBoss() || isAdmin() || (isSignedIn() && resource.data.evaluateeId == request.auth.token.email);
    }
  }
}
