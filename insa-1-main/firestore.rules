rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function getUser(email) {
      return get(/databases/$(database)/documents/users/$(email)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && getUser(request.auth.token.email).role == 'admin';
    }

    function isHr() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && (getUser(request.auth.token.email).role == 'admin' || getUser(request.auth.token.email).role == 'hr');
    }

    function isGroupLeader() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && ('position' in getUser(request.auth.token.email)) && getUser(request.auth.token.email).position.matches('^.+그룹장$');
    }

    function isBoss() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email)) && ('position' in getUser(request.auth.token.email)) && getUser(request.auth.token.email).position == '사장';
    }

    // 사용자별 개별 메뉴 권한 체크
    function hasMenuAccess(menuPath) {
      let u = getUser(request.auth.token.email);
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && 'menuPermissions' in u
        && menuPath in u.menuPermissions
        && u.menuPermissions[menuPath] == true;
    }

    // 역할별 메뉴 권한 체크 (settings/menuPermissions 기반)
    function hasRoleMenuAccess(menuPath) {
      let u = getUser(request.auth.token.email);
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.token.email))
        && exists(/databases/$(database)/documents/settings/menuPermissions)
        && menuPath in get(/databases/$(database)/documents/settings/menuPermissions).data
        && u.role in get(/databases/$(database)/documents/settings/menuPermissions).data[menuPath]
        && get(/databases/$(database)/documents/settings/menuPermissions).data[menuPath][u.role] == true;
    }

    // 개별 또는 역할별 메뉴 권한 중 하나라도 허용
    function canAccessMenu(menuPath) {
      return hasMenuAccess(menuPath) || hasRoleMenuAccess(menuPath);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.token.email));

      allow update: if (
        isSignedIn() && (
          isAdmin() ||
          (request.auth.token.email == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'department', 'updatedAt', 'uid']))
        )
      );

      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow list: if isHr() || isAdmin() || canAccessMenu('/admin/users');
    }

    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/menuPermissions {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /years/{yearId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isHr();
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isHr() || canAccessMenu('/admin/items');
    }

    match /assignments/{assignmentId} {
      allow read: if isSignedIn() && (isHr() || isGroupLeader() || isBoss() || canAccessMenu('/admin/assignments') || existing().evaluatorId == request.auth.token.email || existing().evaluateeId == request.auth.token.email);
      allow create, delete: if (isHr() || canAccessMenu('/admin/assignments')) && isValidId(assignmentId);
      allow update: if isHr() || isGroupLeader() || canAccessMenu('/admin/assignments') || (
        isSignedIn() && existing().evaluatorId == request.auth.token.email
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore'])
        && incoming().totalScore is number && incoming().totalScore >= 0
      );
      allow list: if isHr() || isGroupLeader() || isBoss() || canAccessMenu('/admin/assignments') || canAccessMenu('/admin/results') || (isSignedIn() && (resource.data.evaluatorId == request.auth.token.email || resource.data.evaluateeId == request.auth.token.email));
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && (
        isHr() || isGroupLeader() || isBoss() || canAccessMenu('/admin/results') ||
        get(/databases/$(database)/documents/assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isHr() || isGroupLeader() || canAccessMenu('/admin/results') ||
        get(/databases/$(database)/documents/assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /finalScores/{finalScoreId} {
      allow read: if isSignedIn() && (isHr() || isGroupLeader() || isBoss() || canAccessMenu('/admin/results') || existing().evaluateeId == request.auth.token.email);
      allow create, update: if isHr() || isGroupLeader() || canAccessMenu('/admin/results');
      allow delete: if isHr() || isGroupLeader() || canAccessMenu('/admin/results');
      allow list: if isHr() || isGroupLeader() || isBoss() || canAccessMenu('/admin/results') || (isSignedIn() && resource.data.evaluateeId == request.auth.token.email);
    }

    match /exec_items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isHr() || isBoss() || canAccessMenu('/admin/items-executive');
    }

    match /exec_assignments/{assignmentId} {
      allow read: if isSignedIn() && (isHr() || isBoss() || canAccessMenu('/admin/assignments-executive') || existing().evaluatorId == request.auth.token.email || existing().evaluateeId == request.auth.token.email);
      allow create, delete: if (isHr() || isBoss() || canAccessMenu('/admin/assignments-executive')) && isValidId(assignmentId);
      allow update: if isHr() || isBoss() || canAccessMenu('/admin/assignments-executive') || (
        isSignedIn() && existing().evaluatorId == request.auth.token.email
        && existing().status != 'completed'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'totalScore'])
        && incoming().totalScore is number && incoming().totalScore >= 0
      );
      allow list: if isHr() || isBoss() || canAccessMenu('/admin/assignments-executive') || canAccessMenu('/admin/results-executive') || (isSignedIn() && (resource.data.evaluatorId == request.auth.token.email || resource.data.evaluateeId == request.auth.token.email));
    }

    match /exec_results/{resultId} {
      allow read: if isSignedIn() && (
        isHr() || isBoss() || canAccessMenu('/admin/results-executive') ||
        get(/databases/$(database)/documents/exec_assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow create: if isSignedIn() && (
        isHr() || isBoss() || canAccessMenu('/admin/results-executive') ||
        get(/databases/$(database)/documents/exec_assignments/$(resultId)).data.evaluatorId == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    match /exec_finalScores/{finalScoreId} {
      allow read: if isSignedIn() && (isBoss() || isAdmin() || canAccessMenu('/admin/results-executive') || existing().evaluateeId == request.auth.token.email);
      allow write: if isBoss() || isAdmin() || canAccessMenu('/admin/results-executive');
      allow list: if isBoss() || isAdmin() || canAccessMenu('/admin/results-executive') || (isSignedIn() && resource.data.evaluateeId == request.auth.token.email);
    }
  }
}
